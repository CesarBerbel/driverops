# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# Every variable below is consumed by docker-compose.yml and passed through
# to the backend/frontend containers. Nothing here is a real secret.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# dev | prod  -- selects backend/config/settings/{dev,prod}.py
DJANGO_ENV=dev

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
# Any random string in dev. Generate a real secret for prod, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=dev-insecure-secret-key-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
POSTGRES_DB=driverops
POSTGRES_USER=driverops
POSTGRES_PASSWORD=driverops
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# CORS / frontend origin
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# JWT cookie auth
# ---------------------------------------------------------------------------
ACCESS_TOKEN_LIFETIME_MIN=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------------------------------------------------------------------------
# Email (dev: Mailpit SMTP, no auth/TLS)
# ---------------------------------------------------------------------------
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=DriverOps <no-reply@driverops.local>

# ---------------------------------------------------------------------------
# Superuser bootstrap (used by `make seed-admin` / scripts/create-superuser.sh)
# Local/dev credentials only -- see README for the documented dev login.
# ---------------------------------------------------------------------------
DJANGO_SUPERUSER_EMAIL=admin@driverops.local
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!
DJANGO_SUPERUSER_NAME=Admin DriverOps

# ---------------------------------------------------------------------------
# Frontend (Vite -- must be prefixed VITE_ to be exposed to the browser)
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api
