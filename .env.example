# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# Every variable below is consumed by docker-compose.yml and passed through
# to the backend/frontend containers. Nothing here is a real secret.

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
# dev | prod  -- selects backend/config/settings/{dev,prod}.py
DJANGO_ENV=dev

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
# Any random string in dev. Generate a real secret for prod, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=dev-insecure-secret-key-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
POSTGRES_DB=driverops
POSTGRES_USER=driverops
POSTGRES_PASSWORD=driverops
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# CORS / frontend origin
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# JWT cookie auth
# ---------------------------------------------------------------------------
ACCESS_TOKEN_LIFETIME_MIN=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------------------------------------------------------------------------
# Email (dev: Mailpit SMTP, no auth/TLS)
# ---------------------------------------------------------------------------
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=DriverOps <no-reply@driverops.local>

# ---------------------------------------------------------------------------
# Superuser bootstrap (used by `make seed-admin` / scripts/create-superuser.sh)
# Local/dev credentials only -- see README for the documented dev login.
# ---------------------------------------------------------------------------
DJANGO_SUPERUSER_EMAIL=admin@driverops.local
DJANGO_SUPERUSER_PASSWORD=ChangeMe123!
DJANGO_SUPERUSER_NAME=Admin DriverOps

# ---------------------------------------------------------------------------
# Assistente de IA (provedor padrão: OpenAI). A chave NÃO é guardada no banco --
# só o nome da env var. Deixe em branco para desativar a IA.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Login com Google (OAuth). Crie um "OAuth 2.0 Client ID" (tipo: Web) no Google
# Cloud Console e autorize a origem do frontend (ex.: http://localhost:5173).
# O MESMO Client ID vai no backend (verifica o token) e no frontend (VITE_...).
# Deixe em branco para desativar o login com Google.
# ---------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=

# ---------------------------------------------------------------------------
# Frontend (Vite -- must be prefixed VITE_ to be exposed to the browser)
# ---------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000/api
# Mesmo valor de GOOGLE_OAUTH_CLIENT_ID acima (exposto ao navegador).
VITE_GOOGLE_CLIENT_ID=

# ---------------------------------------------------------------------------
# Observability / logging
# ---------------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Opcional: se definido (e sentry-sdk instalado), ativa captura de erros em prod.
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0
# SENTRY_ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Produção (só relevante com DJANGO_ENV=prod)
# ---------------------------------------------------------------------------
# HSTS: default 1 ano. Só habilite includeSubDomains/preload quando tiver
# certeza de que TODO o domínio serve HTTPS.
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=False
# DJANGO_SECURE_SSL_REDIRECT=True
# Cookies Secure em dev ficam desligados; em prod são forçados.
# DJANGO_COOKIE_SECURE=True

# Jobs periódicos (notifications-cron): intervalo entre ciclos, em segundos.
# NOTIFICATIONS_SYNC_INTERVAL=3600

# Réplicas de app: com o serviço backend-migrate aplicando as migrations uma vez,
# o backend sobe com RUN_MIGRATIONS=0 (já é o padrão no docker-compose.prod.yml).
# Para um app single-instance sem o init, use RUN_MIGRATIONS=1.
# RUN_MIGRATIONS=0

# Backups (serviço db-backup)
# BACKUP_INTERVAL=86400            # segundos entre backups (padrão: diário)
# BACKUP_RETENTION=14              # quantos manter de cada tipo (db/mídia)
# Alerta em falha (Slack/Discord/Mattermost): recebe um POST JSON.
# BACKUP_ALERT_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ
# Armazenamento externo S3-compatível (recomendado -- protege contra perda do host).
# BACKUP_S3_BUCKET=meu-bucket-de-backups
# BACKUP_S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com   # só p/ S3-compatível
# (as credenciais AWS vêm das vars padrão: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY)
